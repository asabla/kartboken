{
  "name": "kartboken",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm --filter @kartboken/web dev",
    "build": "pnpm catalog:validate && pnpm --filter @kartboken/web build",
    "check": "pnpm catalog:validate && pnpm -r --if-present check",
    "test": "vitest run --exclude '**/*.fuzz.test.ts' --exclude 'tests/e2e/**'",
    "test:fuzz": "vitest run fuzz.test --exclude 'tests/e2e/**'",
    "test:e2e": "pnpm build && playwright test",
    "catalog:validate": "pnpm --filter @kartboken/catalog-cli validate"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.10.0",
    "fast-check": "^4.9.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.10"
  }
}
